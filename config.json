{
  "quality_presets": {
    "ultra_high": {
      "crf": 15,
      "preset": "slow",
      "description": "Ultra high quality, largest file size. Best for professional work and archival.",
      "typical_reduction": "20-30%"
    },
    "high": {
      "crf": 18,
      "preset": "medium",
      "description": "High quality with good compression. Suitable for streaming and high-quality storage.",
      "typical_reduction": "30-40%"
    },
    "balanced": {
      "crf": 23,
      "preset": "medium",
      "description": "Balanced quality and compression. Default and recommended for most use cases.",
      "typical_reduction": "40-50%"
    },
    "medium": {
      "crf": 28,
      "preset": "fast",
      "description": "Medium quality with faster encoding. Good for social media and quick sharing.",
      "typical_reduction": "50-60%"
    },
    "low": {
      "crf": 32,
      "preset": "veryfast",
      "description": "Low quality with maximum compression. Fastest encoding, smallest files.",
      "typical_reduction": "60-70%"
    }
  },
  "audio_codecs": {
    "aac": {
      "codec": "aac",
      "bitrate": "128k",
      "description": "High-quality audio codec, universal compatibility",
      "bitrate_range": "96k-320k"
    },
    "mp3": {
      "codec": "libmp3lame",
      "bitrate": "128k",
      "description": "Maximum compatibility across all devices",
      "bitrate_range": "64k-320k"
    },
    "opus": {
      "codec": "libopus",
      "bitrate": "128k",
      "description": "Modern codec with excellent quality at low bitrate",
      "bitrate_range": "6k-256k"
    },
    "copy": {
      "codec": "copy",
      "bitrate": null,
      "description": "Copy original audio without re-encoding (fastest)",
      "note": "No re-encoding, preserves original audio quality"
    }
  },
  "default_settings": {
    "quality": "balanced",
    "audio_codec": "aac",
    "keep_original": true,
    "output_format": "mp4",
    "video_codec": "libx264",
    "movflags": "+faststart"
  },
  "supported_formats": {
    "video_input": ["mp4", "avi", "mkv", "mov", "flv", "wmv", "webm", "3gp", "ogv", "ts", "m2ts", "mts", "m2v", "m4v"],
    "video_output": ["mp4"],
    "audio_input": ["aac", "mp3", "m4a", "opus", "flac", "wav", "wma"]
  }
}
